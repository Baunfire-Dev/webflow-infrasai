{
    "devDependencies": {
        "autoprefixer": "latest",
        "axios": "^1.18.1",
        "concurrently": "^10.0.3",
        "esbuild": "^0.25.4",
        "fluid-tailwind": "latest",
        "ora": "^9.4.1",
        "postcss": "latest",
        "postcss-import": "latest",
        "postcss-import-ext-glob": "latest",
        "postcss-nested": "latest",
        "postcss-nesting": "latest",
        "tailwindcss": "^3.4.17"
    },
    "scripts": {
        "dev": "concurrently -n tailwind,javascript,cloudflare -c \"#38BDF8,#F7DF1E,#F38020\" \"npm:tw\" \"npm:js\" \"npm:deploy:watch:plain\"",
        "dev:local": "concurrently -n tailwind,javascript,local -c \"#38BDF8,#F7DF1E,#A78BFA\" \"npm:tw\" \"npm:js\" \"npm:local\"",
        "local": "npx serve . -l 3000",
        "js": "node build/compile-scripts.js --watch",
        "tw": "npx tailwindcss -i assets/css/theme/tailwind.css -o assets/css/bundles/styles.css --postcss --watch --poll --minify",
        "deploy:watch": "node build/cloudflare-watch.js",
        "deploy:watch:plain": "node build/cloudflare-watch.js --plain"
    },
    "dependencies": {
        "gsap": "^3.12.5",
        "lenis": "^1.3.23"
    }
}